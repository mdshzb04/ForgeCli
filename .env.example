# ForgeCLI environment variables
# Alternatively, run `forge init` which generates this automatically.



# AI Provider API Keys
# The router (`forge model auto`) reads these env vars to decide which
# providers have credentials available. Set at least one to leave the
# "mock" fallback behind.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=         
MISTRAL_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=



